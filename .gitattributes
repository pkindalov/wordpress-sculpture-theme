# Normalize line endings to LF for all text files
* text=auto eol=lf

*.php  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.svg  text eol=lf
*.html text eol=lf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
